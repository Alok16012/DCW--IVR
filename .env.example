# ---------------------------------------------------------------------------
# DCW-IVR — environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# ---------------------------------------------------------------------------

# Supabase project (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres connection string, used only by scripts/apply-migration.ts
# (Project Settings → Database → Connection string / URI, include the password)
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT-ref.supabase.co:5432/postgres

# Telephony provider: "mock" (default, works with no external account)
# or "exotel" (requires a live Exotel account + the credentials below)
TELEPHONY_PROVIDER=mock

# Exotel — leave blank until the client's Exotel account + KYC is provisioned
EXOTEL_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_CALLER_ID=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret shared with Vercel Cron to authorize maintenance jobs
# (retry-webhooks, retention). Generate a long random string.
CRON_SECRET=change-me-to-a-long-random-string
